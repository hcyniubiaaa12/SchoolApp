// Login.ets - зҷ»еҪ•йЎөпјҲStartAbilityеҶ…пјү
import { common, Want } from '@kit.AbilityKit';
import { preferences } from '@kit.ArkData';
import { router } from '@kit.ArkUI';
import promptAction from '@ohos.promptAction';

@Entry
@Component
struct Login {
  // зҷ»еҪ•иЎЁеҚ•зҠ¶жҖҒ
  @State studentId: string = '';
  @State password: string = '';
  @State showPassword: boolean = false;

  private context: common.UIAbilityContext = getContext(this) as common.UIAbilityContext;

  private nameMap: Record<string, string> = {
    '202410290123': 'еј еҗҢеӯҰ',
    '202410290124': 'жқҺеҗҢеӯҰ',
    '202410290125': 'зҺӢеҗҢеӯҰ',
    '202410290126': 'иөөеҗҢеӯҰ',
    '202410290127': 'еҲҳеҗҢеӯҰ'
  };

  private getNameById(id: string): string {
    return this.nameMap[id] ?? id;
  }

  private isLoginActive(): boolean {
    return this.studentId.length > 0 && this.password.length > 0;
  }

  // зҷ»еҪ•жҲҗеҠҹеҗҺи·іиҪ¬еҲ°MainAbilityпјҲAbilityзә§еҲ«и·іиҪ¬пјү
  private doLogin(): void {
    if (!this.studentId) {
      promptAction.showToast({ message: 'иҜ·иҫ“е…ҘеӯҰеҸ·' });
      return;
    }
    if (!this.password) {
      promptAction.showToast({ message: 'иҜ·иҫ“е…ҘеҜҶз Ғ' });
      return;
    }

    const username = this.getNameById(this.studentId);

    // дҝқеӯҳз”ЁжҲ·дҝЎжҒҜеҲ°жң¬ең°еӯҳеӮЁ
    try {
      const pref = preferences.getPreferencesSync(this.context, { name: 'school_app_prefs' });
      pref.putSync('saved_user_id', this.studentId);
      pref.putSync('saved_username', username);
      pref.flushSync();
      console.log('>>> [Login] з”ЁжҲ·дҝЎжҒҜе·Ідҝқеӯҳ - userId: ' + this.studentId + ', username: ' + username);
    } catch (err) {
      console.error('>>> [Login] дҝқеӯҳз”ЁжҲ·дҝЎжҒҜеӨұиҙҘ: ' + JSON.stringify(err));
    }

    // ж Үи®°зҷ»еҪ•зҠ¶жҖҒпјҲе…је®№ StartAbility eventHubпјү
    this.context.eventHub.emit('markLoginStatus', true);

    // и®ҫзҪ® AppStorage дҫӣ Index йЎөйқўиҜ»еҸ–
    AppStorage.setOrCreate('userId', this.studentId);
    AppStorage.setOrCreate('username', username);

    // зӣҙжҺҘи·іиҪ¬йҰ–йЎөпјҲжё…з©әи·Ҝз”ұж ҲпјҢйҒҝе…Қ Navigation еөҢеҘ—еҶІзӘҒпјү
    try {
      router.clear();
      router.pushUrl({ url: 'pages/Index' });
      promptAction.showToast({ message: 'зҷ»еҪ•жҲҗеҠҹ' });
    } catch (err) {
      console.error('>>> [Login] и·іиҪ¬йҰ–йЎөеӨұиҙҘ: ' + JSON.stringify(err));
      promptAction.showToast({ message: 'и·іиҪ¬еӨұиҙҘпјҢиҜ·йҮҚиҜ•' });
    }
  }

  // и·іиҪ¬еҲ°жіЁеҶҢйЎөпјҲAbilityеҶ…йЎөйқўи·іиҪ¬пјү
  private navigateToRegist(): void {
    this.context.eventHub.emit('navigateToRegist');
  }

  build() {
    Column() {
      // ж ҮйўҳеҢәеҹҹ
      Column({ space: 12 }) {
        Row() {
          Text('ж¬ўиҝҺеӣһжқҘ')
            .fontSize(24)
            .fontWeight(FontWeight.Bold)
            .fontColor('#333333')

          // й»„иүІйёӯеӯҗиЎЁжғ…
          Text('рҹҰҶ')
            .fontSize(20)
            .margin({ left: 8 })
        }

        Text('иҜ·зҷ»еҪ•жӮЁзҡ„й«ҳж Ўж ЎеӣӯеҠ©жүӢиҙҰеҸ·')
          .fontSize(14)
          .fontColor('#666666')
      }
      .width('100%')
      .padding({ top: 60, left: 24, right: 24 })
      .alignItems(HorizontalAlign.Start)

      // иЎЁеҚ•еҢәеҹҹ
      Column({ space: 20 }) {
        // жүӢжңәеҸ·/еӯҰеҸ·иҫ“е…ҘжЎҶ - еёҰж Үзӯҫ
        Column({ space: 8 }) {
          Text('жүӢжңәеҸ· / еӯҰеҸ·')
            .fontSize(14)
            .fontColor('#666666')
            .width('100%')

          Row() {
            Image($r('app.media.ic_account'))
              .width(20)
              .height(20)
              .fillColor('#999999')
              .margin({ right: 10 })

            TextInput({ placeholder: 'иҜ·иҫ“е…ҘжӮЁзҡ„иҙҰеҸ·' })
              .fontSize(16)
              .fontColor('#333333')
              .backgroundColor(Color.Transparent)
              .border({ width: 0 })
              .layoutWeight(1)
              .onChange((value: string) => { this.studentId = value; })
          }
          .height(48)
          .padding({ left: 16, right: 16 })
          .borderRadius(8)
          .backgroundColor('#FFFFFF')
          .border({ width: 1, color: '#E0E0E0', radius: 8 })
        }
        .width('100%')
        .alignItems(HorizontalAlign.Start)

        // еҜҶз Ғиҫ“е…ҘжЎҶ - еёҰж Үзӯҫ
        Column({ space: 8 }) {
          Row() {
            Text('еҜҶз Ғ')
              .fontSize(14)
              .fontColor('#666666')

            Blank()

            Text('еҝҳи®°еҜҶз Ғпјҹ')
              .fontSize(14)
              .fontColor('#1677FF')
              .onClick(() => {
                promptAction.showToast({ message: 'еҝҳи®°еҜҶз ҒеҠҹиғҪејҖеҸ‘дёӯ' });
              })
          }
          .width('100%')

          Row() {
            Image($r('app.media.ic_lock'))
              .width(20)
              .height(20)
              .fillColor('#999999')
              .margin({ right: 10 })

            TextInput({ placeholder: 'иҜ·иҫ“е…ҘжӮЁзҡ„еҜҶз Ғ' })
              .fontSize(16)
              .fontColor('#333333')
              .backgroundColor(Color.Transparent)
              .border({ width: 0 })
              .layoutWeight(1)
              .type(this.showPassword ? InputType.Normal : InputType.Password)
              .onChange((value: string) => { this.password = value; })

            // жҳҫзӨә/йҡҗи—ҸеҜҶз Ғ
            Image($r('app.media.ic_code'))
              .width(20)
              .height(20)
              .fillColor(this.showPassword ? '#1677FF' : '#999999')
              .onClick(() => { this.showPassword = !this.showPassword; })
          }
          .height(48)
          .padding({ left: 16, right: 16 })
          .borderRadius(8)
          .backgroundColor('#FFFFFF')
          .border({ width: 1, color: '#E0E0E0', radius: 8 })
        }
        .width('100%')
        .alignItems(HorizontalAlign.Start)

        // зҷ»еҪ•жҢүй’®
        Button('зҷ»еҪ•')
          .width('100%')
          .height(48)
          .fontSize(16)
          .fontWeight(FontWeight.Medium)
          .fontColor(this.isLoginActive() ? Color.White : '#86909C')
          .backgroundColor(this.isLoginActive() ? '#1677FF' : '#C6E2FF')
          .borderRadius(8)
          .margin({ top: 8 })
          .onClick(() => { this.doLogin(); })
      }
      .width('100%')
      .padding({ left: 24, right: 24 })
      .margin({ top: 32 })

      Blank()

      // з¬¬дёүж–№зҷ»еҪ•еҢәеҹҹ
      Column({ space: 12 }) {
        Text('з¬¬дёүж–№зҷ»еҪ•')
          .fontSize(12)
          .fontColor('#999999')

        Row({ space: 20 }) {
          // еҫ®дҝЎеӣҫж Ү
          Stack() {
            Circle()
              .width(40)
              .height(40)
              .fill('#07C160')
            Text('еҫ®')
              .fontSize(14)
              .fontColor('#FFFFFF')
          }

          // QQеӣҫж Ү
          Stack() {
            Circle()
              .width(40)
              .height(40)
              .fill('#12B7F5')
            Text('Q')
              .fontSize(14)
              .fontColor('#FFFFFF')
          }
        }
      }
      .margin({ bottom: 20 })

      // еә•йғЁжіЁеҶҢе…ҘеҸЈ
      Row() {
        Text('иҝҳжІЎжңүиҙҰеҸ·пјҹ')
          .fontSize(14)
          .fontColor('#666666')
        Text('з«ӢеҚіжіЁеҶҢ')
          .fontSize(14)
          .fontColor('#1677FF')
          .fontWeight(FontWeight.Medium)
          .onClick(() => {
            this.navigateToRegist();
          })
      }
      .margin({ bottom: 30 })
    }
    .width('100%')
    .height('100%')
    .backgroundColor('#F5F7FA')
    .alignItems(HorizontalAlign.Center)
  }
}
