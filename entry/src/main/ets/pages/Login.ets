// Login.ets - зҷ»еҪ•йЎөпјҲStartAbilityеҶ…пјү
import { common } from '@kit.AbilityKit';
import { router } from '@kit.ArkUI';
import promptAction from '@ohos.promptAction';
import { UserDao } from '../common/database/UserDao';

@Entry
@Component
struct Login {
  // зҷ»еҪ•иЎЁеҚ•зҠ¶жҖҒ
  @State studentId: string = '';
  @State password: string = '';
  @State showPassword: boolean = false;
  @State isIdFocused: boolean = false;
  @State isPwdFocused: boolean = false;

  private context: common.UIAbilityContext = getContext(this) as common.UIAbilityContext;

  private nameMap: Record<string, string> = {
    '202410290123': 'еј еҗҢеӯҰ',
    '202410290124': 'жқҺеҗҢеӯҰ',
    '202410290125': 'зҺӢеҗҢеӯҰ',
    '202410290126': 'иөөеҗҢеӯҰ',
    '202410290127': 'еҲҳеҗҢеӯҰ'
  };

  private getNameById(id: string): string {
    return this.nameMap[id] ?? id;
  }

  private isLoginActive(): boolean {
    return this.studentId.length > 0 && this.password.length > 0;
  }

  private async doLogin(): Promise<void> {
    if (!this.studentId) {
      promptAction.showToast({ message: 'иҜ·иҫ“е…ҘеӯҰеҸ·' });
      return;
    }
    if (!this.password) {
      promptAction.showToast({ message: 'иҜ·иҫ“е…ҘеҜҶз Ғ' });
      return;
    }

    // 1. е…ҲжҹҘжҳҜеҗҰжҳҜйў„зҪ®жј”зӨәиҙҰеҸ·пјҲnameMap дёӯжңүпјҢе…ҚеҜҶз Ғж ЎйӘҢпјү
    let username = this.getNameById(this.studentId);
    let isDemoAccount = this.nameMap[this.studentId] !== undefined;
    let isValid = false;

    if (!isDemoAccount) {
      // 2. йқһжј”зӨәиҙҰеҸ·пјҡйҖҡиҝҮ UserDao ж ЎйӘҢ
      const ok = await UserDao.login(this.context, this.studentId, this.password);
      if (!ok) {
        // е°қиҜ•жҹҘз”ЁжҲ·жҳҜеҗҰеӯҳеңЁ
        const user = UserDao.findByIdSync(this.context, this.studentId);
        if (user.userId !== this.studentId) {
          promptAction.showToast({ message: 'иҜҘиҙҰеҸ·жңӘжіЁеҶҢпјҢиҜ·е…ҲжіЁеҶҢ' });
          return;
        }
        promptAction.showToast({ message: 'еҜҶз Ғй”ҷиҜҜпјҢиҜ·йҮҚиҜ•' });
        return;
      }
      isValid = true;
      username = UserDao.findByIdSync(this.context, this.studentId).username;
    } else {
      // жј”зӨәиҙҰеҸ·пјҡзӣҙжҺҘйҖҡиҝҮ
      isValid = true;
    }

    if (!isValid) {
      return;
    }

    // дҝқеӯҳзҷ»еҪ•жҖҒе’Ң AppStorage
    await UserDao.setLoggedIn(this.context, true);
    await UserDao.setCurrentUserId(this.context, this.studentId);
    AppStorage.setOrCreate('userId', this.studentId);
    AppStorage.setOrCreate('username', username);

    // ж Үи®°зҷ»еҪ•зҠ¶жҖҒпјҲе…је®№ StartAbility eventHubпјү
    this.context.eventHub.emit('markLoginStatus', true);

    // зӣҙжҺҘи·іиҪ¬йҰ–йЎөпјҲжё…з©әи·Ҝз”ұж ҲпјҢйҒҝе…Қ Navigation еөҢеҘ—еҶІзӘҒпјү
    try {
      router.clear();
      router.pushUrl({ url: 'pages/Index' });
      promptAction.showToast({ message: 'зҷ»еҪ•жҲҗеҠҹ' });
    } catch (err) {
      console.error('>>> [Login] и·іиҪ¬йҰ–йЎөеӨұиҙҘ: ' + JSON.stringify(err));
      promptAction.showToast({ message: 'и·іиҪ¬еӨұиҙҘпјҢиҜ·йҮҚиҜ•' });
    }
  }

  // и·іиҪ¬еҲ°жіЁеҶҢйЎөпјҲAbilityеҶ…йЎөйқўи·іиҪ¬пјү
  private navigateToRegist(): void {
    this.context.eventHub.emit('navigateToRegist');
  }

  build() {
    Column() {
      // ж ҮйўҳеҢәеҹҹ
      Column({ space: 12 }) {
        Row() {
          Text('ж¬ўиҝҺеӣһжқҘ')
            .fontSize(24)
            .fontWeight(FontWeight.Bold)
            .fontColor($r('app.color.text_primary'))

          // й»„иүІйёӯеӯҗиЎЁжғ…
          Text('рҹҰҶ')
            .fontSize(20)
            .margin({ left: 8 })
        }

        Text('иҜ·зҷ»еҪ•жӮЁзҡ„й«ҳж Ўж ЎеӣӯеҠ©жүӢиҙҰеҸ·')
          .fontSize(14)
          .fontColor($r('app.color.text_secondary'))
      }
      .width('100%')
      .padding({ top: 60, left: 24, right: 24 })
      .alignItems(HorizontalAlign.Start)

      // иЎЁеҚ•еҢәеҹҹ
      Column({ space: 20 }) {
        // жүӢжңәеҸ·/еӯҰеҸ·иҫ“е…ҘжЎҶ - еёҰж ҮзӯҫпјҲиҒҡз„Ұиҫ№жЎҶеҸҳи“қпјү
        Column({ space: 8 }) {
          Text('жүӢжңәеҸ· / еӯҰеҸ·')
            .fontSize(14)
            .fontColor($r('app.color.text_secondary'))
            .width('100%')

          Row() {
            Image($r('app.media.ic_account'))
              .width(20)
              .height(20)
              .fillColor(this.isIdFocused ? $r('app.color.primary') : $r('app.color.text_secondary'))
              .margin({ right: 10 })

            TextInput({ placeholder: 'иҜ·иҫ“е…ҘжӮЁзҡ„иҙҰеҸ·' })
              .fontSize(16)
              .fontColor($r('app.color.text_primary'))
              .backgroundColor(Color.Transparent)
              .border({ width: 0 })
              .layoutWeight(1)
              .onChange((value: string) => { this.studentId = value; })
              .onFocus(() => { this.isIdFocused = true; })
              .onBlur(() => { this.isIdFocused = false; })
          }
          .height(48)
          .padding({ left: 16, right: 16 })
          .borderRadius(8)
          .backgroundColor($r('app.color.card_white'))
          .border({ width: 1, color: this.isIdFocused ? $r('app.color.primary') : $r('app.color.border'), radius: 8 })
        }
        .width('100%')
        .alignItems(HorizontalAlign.Start)

        // еҜҶз Ғиҫ“е…ҘжЎҶ - еёҰж ҮзӯҫпјҲиҒҡз„Ұиҫ№жЎҶеҸҳи“қпјү
        Column({ space: 8 }) {
          Row() {
            Text('еҜҶз Ғ')
              .fontSize(14)
              .fontColor($r('app.color.text_secondary'))

            Blank()

            Text('еҝҳи®°еҜҶз Ғпјҹ')
              .fontSize(14)
              .fontColor($r('app.color.primary'))
              .onClick(() => {
                promptAction.showToast({ message: 'еҝҳи®°еҜҶз ҒеҠҹиғҪејҖеҸ‘дёӯ' });
              })
          }
          .width('100%')

          Row() {
            Image($r('app.media.ic_lock'))
              .width(20)
              .height(20)
              .fillColor(this.isPwdFocused ? $r('app.color.primary') : $r('app.color.text_secondary'))
              .margin({ right: 10 })

            TextInput({ placeholder: 'иҜ·иҫ“е…ҘжӮЁзҡ„еҜҶз Ғ' })
              .fontSize(16)
              .fontColor($r('app.color.text_primary'))
              .backgroundColor(Color.Transparent)
              .border({ width: 0 })
              .layoutWeight(1)
              .type(this.showPassword ? InputType.Normal : InputType.Password)
              // е…ій—ӯзі»з»ҹиҮӘеёҰеҜҶз ҒзңјзқӣпјҢйҒҝе…ҚдёҺеҸідҫ§жүӢеҶҷ SymbolGlyph зңјзқӣйҮҚеӨҚжҳҫзӨә
              .showPasswordIcon(false)
              .onChange((value: string) => { this.password = value; })
              .onFocus(() => { this.isPwdFocused = true; })
              .onBlur(() => { this.isPwdFocused = false; })

            // жҳҫзӨә/йҡҗи—ҸеҜҶз Ғ
            SymbolGlyph(this.showPassword ? $r('sys.symbol.eye') : $r('sys.symbol.eye_slash'))
              .fontSize(20)
              .fontColor([this.showPassword ? $r('app.color.primary') : $r('app.color.text_secondary')])
              .onClick(() => { this.showPassword = !this.showPassword; })
          }
          .height(48)
          .padding({ left: 16, right: 16 })
          .borderRadius(8)
          .backgroundColor($r('app.color.card_white'))
          .border({ width: 1, color: this.isPwdFocused ? $r('app.color.primary') : $r('app.color.border'), radius: 8 })
        }
        .width('100%')
        .alignItems(HorizontalAlign.Start)

        // зҷ»еҪ•жҢүй’®
        Button('зҷ»еҪ•')
          .width('100%')
          .height(48)
          .fontSize(16)
          .fontWeight(FontWeight.Medium)
          .fontColor(this.isLoginActive() ? Color.White : $r('app.color.text_secondary'))
          .backgroundColor(this.isLoginActive() ? $r('app.color.primary') : $r('app.color.button_inactive_bg'))
          .borderRadius(8)
          .margin({ top: 8 })
          .onClick(() => { this.doLogin(); })
      }
      .width('100%')
      .padding({ left: 24, right: 24 })
      .margin({ top: 32 })

      Blank()

      // з¬¬дёүж–№зҷ»еҪ•еҢәеҹҹ
      Column({ space: 12 }) {
        Text('з¬¬дёүж–№зҷ»еҪ•')
          .fontSize(12)
          .fontColor($r('app.color.text_secondary'))

        Row({ space: 20 }) {
          // еҫ®дҝЎеӣҫж Ү
          Stack() {
            Circle()
              .width(40)
              .height(40)
              .fill('#07C160')
            Text('еҫ®')
              .fontSize(14)
              .fontColor($r('app.color.card_white'))
          }

          // QQеӣҫж Ү
          Stack() {
            Circle()
              .width(40)
              .height(40)
              .fill('#12B7F5')
            Text('Q')
              .fontSize(14)
              .fontColor($r('app.color.card_white'))
          }
        }
      }
      .margin({ bottom: 20 })

      // еә•йғЁжіЁеҶҢе…ҘеҸЈ
      Row() {
        Text('иҝҳжІЎжңүиҙҰеҸ·пјҹ')
          .fontSize(14)
          .fontColor($r('app.color.text_secondary'))
        Text('з«ӢеҚіжіЁеҶҢ')
          .fontSize(14)
          .fontColor($r('app.color.primary'))
          .fontWeight(FontWeight.Medium)
          .onClick(() => {
            this.navigateToRegist();
          })
      }
      .margin({ bottom: 30 })
    }
    .width('100%')
    .height('100%')
    .backgroundColor($r('app.color.background'))
    .alignItems(HorizontalAlign.Center)
  }
}
